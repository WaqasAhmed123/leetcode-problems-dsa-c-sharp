## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
artifacts/

# Visual Studio 2015/2017/2019/2022
.vs/

# Rider
.idea/
*.sln.iml

# User-specific files
*.user
*.userosscache
*.suo
*.rsuser

# MonoDevelop
*.userprefs

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Test results
TestResults/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# MSBuild
*.publishsettings

# Publish output
publish/

# Resharper
_ReSharper*/
*.DotSettings.user

# DotCover
*.dotCover

# Coverlet
coverage*
*.coverage
*.coveragexml

# VS Code
.vscode/

# JetBrains Rider
.idea/

# Azure
*.azurePubxml

# Windows Store app package directory
AppPackages/

# Others
*.dbmdl
*.jfm
*.pfx
*.publish.xml